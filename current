showScreen('upload');

// Pre-warm voice list on page load so voices are ready before book upload
(function preWarmVoices() {
  const pickBest = () => {
    const preferred = voices.findIndex(v => v.localService && v.lang.startsWith('en'));
    selectedVoice = voices[preferred >= 0 ? preferred : 0] || null;
    voicesReady = true;
    updateCurrentVoiceLabel();
  };
  voices = synth.getVoices().filter(v => v.name && v.name.trim() !== '');
  if (voices.length > 0) { pickBest(); return; }
  const handler = () => {
    voices = synth.getVoices().filter(v => v.name && v.name.trim() !== '');
    if (voices.length > 0) { synth.removeEventListener('voiceschanged', handler); pickBest(); }
  };
  synth.addEventListener('voiceschanged', handler);
  let attempts = 0;
  const poll = setInterval(() => {
    voices = synth.getVoices().filter(v => v.name && v.name.trim() !== '');
    if (voices.length > 0 || ++attempts > 15) {
      clearInterval(poll);
      if (voices.length > 0 && !voicesReady) { synth.removeEventListener('voiceschanged', handler); pickBest(); }
      else if (!voicesReady) document.getElementById('current-voice-name').textContent = 'No voices found';
    }
  }, 200);
})();
